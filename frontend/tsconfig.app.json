{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "forceConsistentCasingInFileNames": true,
    "module": "esnext",
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts",
    "libs/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "libs/**/*.spec.ts"
  ]
}
