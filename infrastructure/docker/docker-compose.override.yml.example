# Copy this file to docker-compose.override.yml for personal customizations.
# docker-compose.override.yml is git-ignored.

services:
  # pgAdmin dashboard for database management
  pgadmin:
    image: dpage/pgadmin4:latest
    container_name: rp-pgadmin
    ports:
      - "5050:80"
    environment:
      PGADMIN_DEFAULT_EMAIL: admin@platform.local
      PGADMIN_DEFAULT_PASSWORD: admin
    networks:
      - platform-network
    depends_on:
      - postgres

  # RedisInsight client for Valkey cache visualization
  redisinsight:
    image: redis/redisinsight:latest
    container_name: rp-redisinsight
    ports:
      - "5540:5540"
    networks:
      - platform-network
    depends_on:
      - valkey
