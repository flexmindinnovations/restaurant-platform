#!/usr/bin/env bash
# Enforce conventional commit message format.
# Format: type(optional-scope): description
# Allowed types: feat, fix, chore, docs, refactor, test, perf, ci, build, style

commit_msg=$(head -1 "$1")

# Allow merge commits and revert commits
if echo "$commit_msg" | grep -qE '^(Merge|Revert) '; then
    exit 0
fi

commit_regex='^(feat|fix|chore|docs|refactor|test|perf|ci|build|style)(\([a-z0-9-]+\))?: .{1,72}'

if ! echo "$commit_msg" | grep -qE "$commit_regex"; then
    echo "ERROR: Commit message does not follow conventional format."
    echo ""
    echo "  Format: type(scope): description"
    echo "  Types:  feat | fix | chore | docs | refactor | test | perf | ci | build | style"
    echo ""
    echo "  Examples:"
    echo "    feat(orders): add place order endpoint"
    echo "    fix(payments): handle timeout on capture"
    echo "    chore(infra): update Terraform modules"
    echo "    docs: update development setup guide"
    echo ""
    echo "  Your message: $commit_msg"
    exit 1
fi
