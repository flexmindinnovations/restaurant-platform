# Application
APP_NAME=restaurant-platform
APP_ENV=local
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=platform
DB_PASSWORD=platform_dev
DB_NAME=restaurant_platform

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# JWT
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS (LocalStack for local dev)
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1

# S3
S3_BUCKET_ASSETS=platform-assets-local
S3_BUCKET_DOCUMENTS=platform-documents-local

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=restaurant-platform-api

# OpenAI (AI module)
OPENAI_API_KEY=sk-placeholder-change-in-production
